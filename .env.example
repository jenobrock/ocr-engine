# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/seedscan-ocr

# Google Cloud Vision (path to service account JSON)
GOOGLE_APPLICATION_CREDENTIALS=./path-to-your-credentials.json

# Auth: shared API key (same for all users) + JWT for signup/login
API_KEY=seedscan-shared-key
JWT_SECRET=your-jwt-secret-at-least-32-chars

# Upload limit (MB)
UPLOAD_MAX_SIZE_MB=20

# Vision API timeout (ms)
VISION_TIMEOUT_MS=60000

# AI Cleaning (OpenAI)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
AI_CLEANING_CONFIDENCE_THRESHOLD=0.8
AI_CLEANING_MAX_CHARS=12000
